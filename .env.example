# Copy this to .env and fill in. Do not commit the real .env.

PUID=1000
PGID=1000
TZ=America/New_York

# Host paths (Windows/Docker Desktop format shown — forward slashes work fine)
MOVIES_PATH=D:/movies
TV_PATH=D:/Tv Shows
DOWNLOADS_PATH=D:/downloads
CONFIG_ROOT=D:/appdata

# --- Gluetun / VPN ---
# See https://github.com/qdm12/gluetun-wiki/tree/main/setup for your provider's
# exact required vars. Below assumes WireGuard against a generic provider.
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
VPN_SERVER_COUNTRIES=

#QBT stuffs
QBITTORRENT_PASS=
QBITTORRENT_USER=

# --- Seedbox: primary downloader for the private tracker ---
# Sonarr/Radarr's TorrentLeech-tagged indexer points its downloadClientId directly
# at a download client on the seedbox (via the Caddy shim below), so the seedbox
# does the actual downloading/seeding -- files get synced back locally afterward
# via a scheduled rclone sync (see README). RATIO_CATEGORY/SEEDBOX_URL/USER/PASS
# aren't read by any container directly -- they're the reference values you use
# when setting up the Caddy shim and the rclone SFTP remote. Only
# SEEDBOX_BASIC_AUTH below is actually consumed (by the caddy service).
RATIO_CATEGORY=ratio
# e.g. https://your-seedbox-host:port (seedbox's qBittorrent WebUI)
SEEDBOX_URL=
SEEDBOX_USER=
SEEDBOX_PASS=
# base64("user:password") for the seedbox's login -- used by the Caddy shim to
# inject the Authorization header the seedbox's reverse proxy requires, since
# Sonarr/Radarr's built-in qBittorrent client has no field for a separate Basic
# Auth layer. Compute with: echo -n "user:pass" | base64
SEEDBOX_BASIC_AUTH=