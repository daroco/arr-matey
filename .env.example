# Copy this to .env and fill in. Do not commit the real .env.
# Prefer running `python scripts/setup.py` instead of editing this by hand --
# it prompts for everything below and writes .env for you.

PUID=1000
PGID=1000
TZ=America/New_York

# Host paths (Windows/Docker Desktop format shown — forward slashes work fine)
# MEDIA_ROOT holds movies/, tv/, and downloads/ as subfolders of ONE mount --
# this is required for Sonarr/Radarr's hardlink import to actually work (see
# README section 9): hardlinks can't cross separate Docker volume mounts, even
# if they're on the same physical drive, so movies/tv/downloads must all live
# under a single bind-mounted parent.
MEDIA_ROOT=D:/media
CONFIG_ROOT=D:/appdata

# --- Which download-client architecture this stack uses ---
# seedbox: everything downloads on a remote seedbox (qBittorrent + Transmission
#   there), synced back locally via rclone. Needs a seedbox subscription and,
#   for full ratio management, a private tracker account. See README section 9.
# local: a single qBittorrent container in this compose file does the actual
#   downloading, no seedbox needed. Zero recurring cost, but: no VPN by
#   default (your home IP is visible to public-torrent swarms -- see README's
#   local-mode section for how to add one back), and no ratio/Hit&Run
#   management (fine for public trackers, not suitable for most private ones).
# DOWNLOAD_MODE only drives scripts/provision.py's wiring -- COMPOSE_PROFILES
# below is the separate, Compose-native switch that actually starts/stops the
# local qBittorrent container. Keep them in sync (scripts/setup.py does this
# for you); provision.py refuses to run if they disagree.
DOWNLOAD_MODE=seedbox
# Set to "local" (and DOWNLOAD_MODE=local above) to start the local qBittorrent
# container; leave blank for seedbox mode.
COMPOSE_PROFILES=

# --- LAN hostnames (Caddy) ---
# Every service gets a clean hostname instead of ip:port, e.g. sonarr.$DOMAIN.
# Use a real domain you own if you have one (a made-up TLD like .home or .lan
# often gets treated as a search query by browsers instead of navigated to,
# since browsers check hostnames against the real Public Suffix List) -- point
# it at your LAN via Pi-hole's Local DNS records (see README section 5), same
# as this stack's own correll.tv setup.
# No domain and no Pi-hole? Use nip.io instead -- a free wildcard DNS service
# that needs no account and no local DNS server: anything.<your-LAN-ip>.nip.io
# resolves straight to <your-LAN-ip>. e.g. if your PC is 192.168.1.50:
#   DOMAIN=192.168.1.50.nip.io
# gives you sonarr.192.168.1.50.nip.io, radarr.192.168.1.50.nip.io, etc. for free.
DOMAIN=

# --- Seedbox mode only (leave blank entirely if DOWNLOAD_MODE=local) ---
# Every Sonarr/Radarr indexer points its downloadClientId directly at a download
# client on the seedbox (via the Caddy shim below) -- the seedbox does the
# actual downloading/seeding, for every tracker, not just one. Files sync back
# locally afterward via a scheduled rclone sync (see README).
# RATIO_CATEGORY/SEEDBOX_URL/USER/PASS aren't read by any container directly --
# they're the reference values you use when setting up the Caddy shim and the
# rclone SFTP remote. Only SEEDBOX_BASIC_AUTH below is actually consumed (by
# the caddy service).
RATIO_CATEGORY=ratio
# e.g. https://your-seedbox-host:port (seedbox's qBittorrent WebUI)
SEEDBOX_URL=
# Just the host[:port] part of SEEDBOX_URL above (Caddy's shim needs the bare
# host, not a full URL) -- e.g. your-seedbox-host:port
SEEDBOX_HOST=
SEEDBOX_USER=
SEEDBOX_PASS=
# base64("user:password") for the seedbox's login -- used by the Caddy shim to
# inject the Authorization header the seedbox's reverse proxy requires, since
# neither Sonarr/Radarr's built-in qBittorrent nor Transmission clients have a
# field for a separate Basic Auth layer. Compute with: echo -n "user:pass" | base64
SEEDBOX_BASIC_AUTH=

# --- Local mode only (leave blank entirely if DOWNLOAD_MODE=seedbox) ---
# The linuxserver/qbittorrent image ignores these at container start -- it
# generates a random temp password on first boot instead. Fill these in with
# whatever permanent password you set during the one-time first-run step (see
# README's local-mode section), which also covers the required Default Save
# Path change. provision.py sets these as Sonarr/Radarr's actual download
# client login -- real credentials, not a bypass of qBittorrent's auth.
QBT_CATEGORY=downloads
QBT_USER=admin
QBT_PASS=

# --- scripts/provision.py: everything below only used by the one-time/idempotent
# bootstrap script that wires up Prowlarr/Sonarr/Radarr/Bazarr/Seerr/the download
# client(s) via API instead of clicking through each UI (see README section 9/setup) ---
# Seedbox mode only:
PUBLIC_CATEGORY=public
PRIVATE_TRACKER_NAME=TorrentLeech
PRIVATE_TRACKER_SEED_RATIO=1
PRIVATE_TRACKER_SEED_TIME_MINUTES=14400
# Optional: override the URLs provision.py talks to (only needed for testing
# against remapped ports/a non-default host -- leave blank to use the normal
# http://localhost:<port> for each app).
SONARR_BASE_URL=
RADARR_BASE_URL=
PROWLARR_BASE_URL=
BAZARR_BASE_URL=
SEERR_BASE_URL=
