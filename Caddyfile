# Internal-only shim: injects the Basic Auth header the seedbox's own reverse
# proxy requires, since neither Sonarr/Radarr's built-in qBittorrent nor
# Transmission clients have a field for a Basic Auth layer separate from their
# own username/password. Proxies the whole seedbox host regardless of path, so
# it works for both qBittorrent (/qbittorrent/...) and Transmission (/rpc) with
# no per-client routing needed. Not published to the host -- only reachable
# from other containers as caddy:8090.
:8090 {
	reverse_proxy https://79.nl73.seedit4.me {
		header_up Host 79.nl73.seedit4.me
		header_up Authorization "Basic {$SEEDBOX_BASIC_AUTH}"
	}
}
