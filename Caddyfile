# Internal-only shim: injects the Basic Auth header the seedbox's own reverse
# proxy requires, since Sonarr/Radarr's built-in qBittorrent client has no field
# for a Basic Auth layer separate from qBittorrent's own username/password. Not
# published to the host -- only reachable from other containers as caddy:8090.
:8090 {
	reverse_proxy https://79.nl73.seedit4.me {
		header_up Host 79.nl73.seedit4.me
		header_up Authorization "Basic {$SEEDBOX_BASIC_AUTH}"
	}
}
